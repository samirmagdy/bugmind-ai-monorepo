{
  "manifest_version": 3,
  "name": "BugMind AI",
  "version": "1.0.0",
  "description": "Enterprise AI assistant for generating high-quality bug reports directly from Jira stories.",
 
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.atlassian.net/*"
  ],
  "optional_host_permissions": [
    "*://*/browse/*",
    "*://*/issues/*",
    "*://*/rest/api/*"
  ],
  "action": {
    "default_title": "Open BugMind AI"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.atlassian.net/browse/*", "https://*.atlassian.net/issues/*"],
      "js": ["assets/content.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
