# App Config
PROJECT_NAME="BugMind AI"
SECRET_KEY="your-super-secret-key-change-it"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bugmind"

# AI Integration
OPENROUTER_API_KEY="your-openrouter-key"
DEFAULT_AI_MODEL="google/gemini-2.0-flash-001"

# Stripe
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
FRONTEND_URL="chrome-extension://..."

# Redis
REDIS_URL="redis://localhost:6379/0"

# Jira
JIRA_ENCRYPTION_KEY="your-32-byte-base64-key"
