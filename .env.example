# App Config
PROJECT_NAME="BugMind AI"
# Generate locally with: openssl rand -hex 64
SECRET_KEY="<generated-secret-key>"
ENVIRONMENT="development"
LOG_LEVEL="INFO"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER="bugmind-api"
JWT_AUDIENCE="bugmind-clients"

# Database
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/bugmind"
# Example managed-hosted database:
# DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# AI Integration
OPENROUTER_API_KEY="<openrouter-api-key>"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"

# Stripe
STRIPE_SECRET_KEY="<stripe-secret-key>"
STRIPE_WEBHOOK_SECRET="<stripe-webhook-secret>"
FRONTEND_URL="chrome-extension://..."

# Redis
REDIS_URL="redis://localhost:6379/0"
CORS_ORIGINS=""
ALLOWED_HOSTS=""

# Jira
# Generate locally with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="<fernet-key>"
ALLOW_INSECURE_JIRA_SSL="false"
